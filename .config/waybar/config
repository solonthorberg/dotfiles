{
  "layer": "top",
  "position": "top",
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["network", "memory", "temperature", "pulseaudio", "custom/power", ],
 
  "clock": {
    "format": "{:%H:%M | %a %d %b}",
    "tooltip": false
  },

  "memory": {
    "interval": 5,
    "format": "󰍛 {used:0.1f}GB",
    "format-alt": "󰍛 {percentage}%",
    "tooltip-format": "{used:0.1f}GB/{total:0.1f}GB",
    "states": {
        "warning": 70,
        "critical": 90
    }
  },

  "temperature": {
    "thermal-zone": 0,
    "critical-threshold": 80,
    "format": "󱃂 {temperatureC}°C",
    "format-critical": "󱃃 {temperatureC}°C"
  },

  "network": {
    "format-wifi": "󰖩 {essid} ({signalStrength}%)",
    "format-ethernet": "󰈀 {ipaddr}",
    "format-disconnected": "󰖪 Disconnected",
    "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}/{cidr}\nFrequency: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
    "tooltip-format-ethernet": "{ifname}\n{ipaddr}/{cidr}\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
    "interval": 5
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "󰖁 {volume}%",
    "format-icons": {
      "default": ["󰕿", "󰖀", "󰕾"]
    },
    "scroll-step": 5,
    "smooth-scrolling-threshold": 1,
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
  },

  "custom/power": {
    "format": "⏻",
    "tooltip-format": "Power Menu",
    "on-click": "$HOME/.local/bin/power-menu"
  },

  "reload_style_on_change": true
}
