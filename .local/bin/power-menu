#!/bin/bash
option=$(echo -e "箚뙻 Lock\n箚쨪 Sleep\n箚쐣 Reboot\n箚맓 Shutdown\n箚뿼 Logout" | wofi --dmenu -p "Power")

case "$option" in
  "箚뙻 Lock") hyprlock ;;
  "箚쨪 Sleep") systemctl suspend ;;
  "箚쐣 Reboot") systemctl reboot ;;
  "箚맓 Shutdown") systemctl poweroff ;;
  "箚뿼 Logout") hyprctl dispatch exit ;;
esac
