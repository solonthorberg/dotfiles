#!/bin/bash
THEME="$1"
THEME_DIR="$HOME/.config/themes/$THEME"

if [ ! -d "$THEME_DIR" ]; then
  echo "Theme '$THEME' not found in ~/.config/themes/"
  exit 1
fi

# Kitty
cp "$THEME_DIR/kitty.conf" ~/.config/kitty/theme.conf
kitty @ set-colors --all ~/.config/kitty/theme.conf

# Hyprland
cp "$THEME_DIR/hyprland.conf" ~/.config/hypr/theme.conf
hyprctl reload

# Waybar
cp "$THEME_DIR/waybar.css" ~/.config/waybar/theme.css
killall -SIGUSR2 waybar

# Neovim
cp "$THEME_DIR/nvim-theme" ~/.config/nvim/current-theme

# Wofi
cp "$THEME_DIR/wofi.css" ~/.config/wofi/style.css

# Zsh syntax highlighting
cp "$THEME_DIR/zsh-sh.zsh" ~/.zsh/current-zsh-sh-theme.zsh

# qBittorrent
QB_THEME=$(cat "$THEME_DIR/qbittorrent")
killall qbittorrent 2>/dev/null
sleep 1
sed -i "s|General\\\\CustomUIThemePath=.*|General\\\\CustomUIThemePath=$HOME/.config/qBittorrent/themes/$QB_THEME|" ~/.config/qBittorrent/qBittorrent.conf

# Spotify
SPICETIFY_SCHEME=$(cat "$THEME_DIR/spicetify")
spicetify config color_scheme "$SPICETIFY_SCHEME"
spicetify apply

# Tmux
TMUX_FLAVOR=$(cat "$THEME_DIR/tmux")
sed -i "s|@catppuccin_flavor.*|@catppuccin_flavor \"$TMUX_FLAVOR\"|" ~/.config/tmux/tmux.conf
tmux source-file ~/.config/tmux/tmux.conf 2>/dev/null

# Zen Browser
ZEN_PROFILE="$HOME/.zen/uqad3y0y.Default (release)"
if [ -d "$ZEN_PROFILE" ]; then
  cp -r "$THEME_DIR/zen/"* "$ZEN_PROFILE/chrome/"
fi

# GTK theme (Nautilus, pavucontrol, etc.)
GTK_THEME=$(cat "$THEME_DIR/gtk")
gsettings set org.gnome.desktop.interface gtk-theme "$GTK_THEME"
killall nautilus 2>/dev/null

# Cursor
CURSOR=$(cat "$THEME_DIR/cursor")
hyprctl setcursor "$CURSOR" 24
gsettings set org.gnome.desktop.interface cursor-theme "$CURSOR"

# Notifications (swaync)
cp "$THEME_DIR/swaync.css" ~/.config/swaync/style.css
sed -i "s/font-family: 'Ubuntu Nerd Font'/font-family: 'JetBrainsMono Nerd Font'/" ~/.config/swaync/style.css
swaync-client -rs
